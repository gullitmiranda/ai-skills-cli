#!/usr/bin/env bash
set -euo pipefail

# ai-skills-cli installer
# Run ./scripts/install --help for usage.

REPO_URL="https://github.com/gullitmiranda/ai-skills-cli.git"
CLONE_DIR="${AI_SKILLS_CLI_DIR:-$HOME/Code/personal/ai-skills-cli}"
BRANCH="main"
SETUP_ARGS=()

_bold()   { printf '\033[1m%s\033[0m' "$*"; }
_green()  { printf '\033[0;32m%s\033[0m' "$*"; }
_yellow() { printf '\033[0;33m%s\033[0m' "$*"; }
_red()    { printf '\033[0;31m%s\033[0m' "$*"; }
_dim()    { printf '\033[2m%s\033[0m' "$*"; }

info()  { echo "  $(_green "✓") $*"; }
warn()  { echo "  $(_yellow "⚠") $*" >&2; }
err()   { echo "  $(_red "✗") $*" >&2; }
die()   { err "$@"; exit 1; }

while [[ $# -gt 0 ]]; do
  case "$1" in
    --clone-dir)  CLONE_DIR="$2"; shift 2 ;;
    --branch)     BRANCH="$2"; shift 2 ;;
    --help|-h)
      cat <<EOF

$(_bold "ai-skills installer")

$(_bold "ONE-LINER")
  curl -fsSL https://raw.githubusercontent.com/gullitmiranda/ai-skills-cli/main/scripts/install | bash

$(_bold "REVIEW BEFORE EXECUTE")
  curl -fsSL https://raw.githubusercontent.com/gullitmiranda/ai-skills-cli/main/scripts/install -o /tmp/ai-skills-install.sh && \\
    less /tmp/ai-skills-install.sh && \\
    read -p "Execute? [y/N] " -n 1 -r && echo && \\
    [[ \$REPLY =~ ^[Yy]\$ ]] && bash /tmp/ai-skills-install.sh

$(_bold "LOCAL")
  ./scripts/install

$(_bold "OPTIONS")
  --clone-dir <dir>  Override clone destination (default: ~/Code/personal/ai-skills-cli)
  --branch <ref>     Branch to clone (default: main)
  --alias <name>     Create an alias symlink (e.g. --alias my-alias)
  --no-doctor        Skip running 'ai-skills doctor' after install
  --install-dir      Override install directory (default: ~/.local/bin)
  --help             Show this help message

EOF
      exit 0
      ;;
    *)  SETUP_ARGS+=("$1"); shift ;;
  esac
done

# --- Detect local vs remote ---

is_local() {
  [[ -n "${BASH_SOURCE[0]:-}" && -f "${BASH_SOURCE[0]}" ]] || return 1
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local repo_dir="$script_dir/.."
  [[ -f "$repo_dir/bin/ai-skills" ]] && CLONE_DIR="$(cd "$repo_dir" && pwd)" && return 0
  return 1
}

if is_local; then
  info "Running from local repo: $CLONE_DIR"
else
  echo ""
  echo "$(_bold "ai-skills-cli installer")"
  echo ""
  echo "  Repository:  $(_dim "$REPO_URL")"
  echo "  Clone to:    $(_dim "$CLONE_DIR")"
  echo "  Branch:      $(_dim "$BRANCH")"
  echo ""

  command -v git &>/dev/null || die "git is required. Install it first."

  if [[ -d "$CLONE_DIR/.git" ]]; then
    info "Repository already cloned at $CLONE_DIR"
    echo "  $(_dim "Pulling latest changes...")"
    git -C "$CLONE_DIR" pull --ff-only origin "$BRANCH" 2>/dev/null || \
      warn "Could not pull latest (may need manual resolution)"
  else
    echo "  Cloning $(_dim "$REPO_URL")..."
    mkdir -p "$(dirname "$CLONE_DIR")"
    git clone --branch "$BRANCH" "$REPO_URL" "$CLONE_DIR"
    info "Cloned to $CLONE_DIR"
  fi

  echo ""
fi

# --- Hand off to setup ---

if [[ ! -x "$CLONE_DIR/scripts/setup" ]]; then
  die "Setup script not found at $CLONE_DIR/scripts/setup"
fi

exec "$CLONE_DIR/scripts/setup" "${SETUP_ARGS[@]+"${SETUP_ARGS[@]}"}"
